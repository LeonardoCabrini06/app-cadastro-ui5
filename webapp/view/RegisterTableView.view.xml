<mvc:View controllerName="appcrud.controller.RegisterTableView"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
	xmlns:l="sap.ui.layout"
	xmlns:f="sap.ui.layout.form"
	xmlns:core="sap.ui.core">
    <Page id="page2" title="Tabela de Registros" showNavButton="true" navButtonPress="onNavBack">
        <VBox class="sapUiMediumMargin">
            <Table items="{lista>/}" id="tabelaUsuarios" mode="Delete" delete="onDelete">
                <columns>
                    <Column >
                        <Text text="ID"></Text>
                    </Column>
                    <Column>
                        <Text text="Nome"/>
                    </Column>
                    <Column>
                        <Text text="Idade"/>
                    </Column>
                    <Column>
                        <Text text="Email"/>
                    </Column>
                    <Column>
                        <Text text="Cidade"/>
                    </Column>
                    <Column>
                        <Text text="Estado"/>
                    </Column>
                    <Column>
                        <Text text="Sexo"/>
                    </Column>
                </columns>

                <items>
                    <ColumnListItem type="Detail" detailPress="onDetailPress">
                        <cells>
                            <Text text="{lista>ID}"/>
                            <Text text="{lista>Nome}"/>
                            <Text text="{lista>Idade}"/>
                            <Text text="{lista>Email}"/>
                            <Text text="{lista>Cidade}"/>
                            <Text text="{lista>Estado}"/>
                            <Text text="{lista>Sexo}"/>
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </VBox>
    </Page>
</mvc:View>